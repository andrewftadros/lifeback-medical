---
import ContactForm from '@components/ContactForm.astro';

const currentYear = new Date().getFullYear();
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const quickLinks = [
  { name: 'Services', href: `${base}/services` },
  { name: 'Meet Our Doctors', href: `${base}/doctors` },
  { name: 'Locations', href: `${base}/locations` },
  { name: 'Testimonials', href: `${base}/testimonials` },
  { name: 'Blog', href: `${base}/blog` },
  { name: 'Book Online', href: `${base}/book-online` },
  { name: 'Preparing for Surgery', href: `${base}/preparing-for-surgery` },
  { name: 'Downloads', href: `${base}/downloads` },
];

const socialGroups = [
  {
    label: 'Life Back Medical',
    links: [
      {
        name: 'Instagram',
        href: 'https://www.instagram.com/lifebackmedical/',
        icon: 'instagram',
      },
      {
        name: 'Facebook',
        href: 'https://www.facebook.com/officallifebackmedical/',
        icon: 'facebook',
      },
    ],
  },
  {
    label: 'Life Back Weight Loss',
    links: [
      {
        name: 'Instagram',
        href: 'https://www.instagram.com/lifebackweightloss/',
        icon: 'instagram',
      },
      {
        name: 'Facebook',
        href: 'https://www.facebook.com/lifebackweightloss/',
        icon: 'facebook',
      },
    ],
  },
  {
    label: 'Life Back Videos',
    links: [
      {
        name: 'YouTube',
        href: 'https://www.youtube.com/channel/UCi5P11phorkXUYexj6CV--Q',
        icon: 'youtube',
      },
    ],
  },
];
---

<footer class="bg-dark text-white">
  <div class="container-default section-padding">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10 lg:gap-8">
      <!-- Column 1: Connect With Us -->
      <div>
        <h3 class="text-lg font-bold text-white mb-4">Connect With Us</h3>
        <ul class="space-y-3 text-gray-300">
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 text-accent shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            <a href="tel:9515472056" class="hover:text-accent transition-colors">951-547-2056</a>
          </li>
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 text-accent shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
            <a href="mailto:info@lifebackmedical.com" class="hover:text-accent transition-colors">info@lifebackmedical.com</a>
          </li>
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 text-accent shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <div>
              <p>Mon - Sat</p>
              <p>9:00 AM - 7:00 PM</p>
            </div>
          </li>
        </ul>
      </div>

      <!-- Column 2: Quick Links -->
      <div>
        <h3 class="text-lg font-bold text-white mb-4">Quick Links</h3>
        <ul class="space-y-2">
          {quickLinks.map((link) => (
            <li>
              <a href={link.href} class="text-gray-300 hover:text-accent transition-colors text-sm">
                {link.name}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Column 3: Follow Us -->
      <div>
        <h3 class="text-lg font-bold text-white mb-4">Follow Us</h3>
        <div class="space-y-4">
          {socialGroups.map((group) => (
            <div>
              <p class="text-sm text-gray-400 mb-2">{group.label}</p>
              <div class="flex gap-2">
                {group.links.map((link) => (
                  <a
                    href={link.href}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="w-9 h-9 rounded-full bg-white/10 flex items-center justify-center hover:bg-primary transition-colors"
                    aria-label={`${group.label} ${link.name}`}
                  >
                    {link.icon === 'instagram' && (
                      <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                        <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z" />
                      </svg>
                    )}
                    {link.icon === 'facebook' && (
                      <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                        <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z" />
                      </svg>
                    )}
                    {link.icon === 'youtube' && (
                      <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                        <path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z" />
                      </svg>
                    )}
                  </a>
                ))}
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Column 4: Contact Us -->
      <div>
        <h3 class="text-lg font-bold text-white mb-4">Contact Us</h3>
        <div class="[&_label]:text-gray-300 [&_input]:bg-white/10 [&_input]:border-white/20 [&_input]:text-white [&_input]:placeholder-gray-400 [&_textarea]:bg-white/10 [&_textarea]:border-white/20 [&_textarea]:text-white [&_textarea]:placeholder-gray-400">
          <ContactForm compact idPrefix="footer" />
        </div>
      </div>
    </div>
  </div>

  <!-- Bottom bar -->
  <div class="border-t border-white/10">
    <div class="container-default px-4 py-6 text-center text-sm text-gray-400">
      <p>Life Back Medical&trade; &amp; Life Back Medical &copy; 2012-{currentYear}</p>
    </div>
  </div>
</footer>
