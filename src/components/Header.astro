---
const currentPath = Astro.url.pathname;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const services = [
  { name: 'Vein Repair', href: `${base}/services/vein-repair` },
  { name: 'Weight Loss', href: `${base}/services/weight-loss` },
  { name: 'Sleep Studies', href: `${base}/services/sleep-studies` },
  { name: 'Cancer Prevention', href: `${base}/services/cancer-prevention` },
  { name: 'Heartburn Relief', href: `${base}/services/heartburn-relief` },
  { name: 'Knee & Back Pain', href: `${base}/services/knee-back-pain` },
  { name: 'Hernia Repair', href: `${base}/services/hernia-repair` },
  { name: 'Gallbladder Surgery', href: `${base}/services/gallbladder-surgery` },
  { name: 'Hemorrhoid Procedures', href: `${base}/services/hemorrhoid-procedures` },
  { name: 'Plastic Surgery', href: `${base}/services/plastic-surgery` },
  { name: 'Colon & Appendix Surgery', href: `${base}/services/colon-appendix-surgery` },
  { name: 'Corporate Wellness', href: `${base}/services/corporate-wellness` },
];

const navLinks = [
  { name: 'Home', href: `${base}/` },
  { name: 'Services', href: `${base}/services`, hasDropdown: true },
  { name: 'Doctors', href: `${base}/doctors` },
  { name: 'Locations', href: `${base}/locations` },
  { name: 'Testimonials', href: `${base}/testimonials` },
  { name: 'Blog', href: `${base}/blog` },
];

function isActive(href: string): boolean {
  if (href === `${base}/`) return currentPath === `${base}/`;
  return currentPath.startsWith(href);
}
---

<header class="sticky top-0 z-50">
  <!-- Top bar -->
  <div class="bg-dark text-white text-sm py-2 px-4">
    <div class="container-default flex items-center justify-center md:justify-end gap-2">
      <svg class="w-4 h-4 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
      </svg>
      <span>Call or text us!</span>
      <a href="tel:9515472056" class="font-semibold text-accent hover:text-white">951-547-2056</a>
    </div>
  </div>

  <!-- Main nav -->
  <nav class="bg-white shadow-md">
    <div class="container-default px-4 flex items-center justify-between h-16 lg:h-20">
      <!-- Logo -->
      <a href={`${base}/`} class="flex items-center gap-1 text-xl md:text-2xl font-bold shrink-0">
        <span class="text-primary">Life Back</span>
        <span class="text-accent">Medical</span>
      </a>

      <!-- Desktop nav links -->
      <ul class="hidden lg:flex items-center gap-6 xl:gap-8">
        {navLinks.map((link) => (
          <li class:list={['relative', { 'group': link.hasDropdown }]}>
            <a
              href={link.href}
              class:list={[
                'text-sm font-medium transition-colors duration-200 py-2 inline-flex items-center gap-1',
                isActive(link.href)
                  ? 'text-primary font-semibold'
                  : 'text-text hover:text-primary',
              ]}
            >
              {link.name}
              {link.hasDropdown && (
                <svg class="w-4 h-4 transition-transform group-hover:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                </svg>
              )}
            </a>
            {link.hasDropdown && (
              <div class="absolute top-full left-1/2 -translate-x-1/2 pt-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200">
                <ul class="bg-white rounded-card shadow-lg border border-gray-100 py-2 min-w-[250px]">
                  {services.map((service) => (
                    <li>
                      <a
                        href={service.href}
                        class:list={[
                          'block px-4 py-2 text-sm transition-colors duration-150',
                          isActive(service.href)
                            ? 'text-primary bg-primary/5 font-medium'
                            : 'text-text hover:bg-primary/5 hover:text-primary',
                        ]}
                      >
                        {service.name}
                      </a>
                    </li>
                  ))}
                </ul>
              </div>
            )}
          </li>
        ))}
      </ul>

      <!-- Desktop CTA -->
      <a href={`${base}/book-online`} class="hidden lg:inline-flex btn-accent text-sm">
        Book Now
      </a>

      <!-- Mobile hamburger -->
      <button
        id="mobile-menu-btn"
        class="lg:hidden p-2 text-text hover:text-primary transition-colors"
        aria-label="Open menu"
        aria-expanded="false"
      >
        <svg id="menu-icon-open" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
        <svg id="menu-icon-close" class="w-6 h-6 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>
  </nav>

  <!-- Mobile menu (full-screen overlay) -->
  <div id="mobile-menu" class="fixed inset-0 top-0 z-50 bg-white hidden flex-col overflow-y-auto">
    <!-- Mobile menu header -->
    <div class="flex items-center justify-between px-4 h-16 border-b border-gray-100">
      <a href={`${base}/`} class="text-xl font-bold">
        <span class="text-primary">Life Back</span>
        <span class="text-accent"> Medical</span>
      </a>
      <button id="mobile-menu-close" class="p-2 text-text hover:text-primary" aria-label="Close menu">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>

    <!-- Mobile menu links -->
    <nav class="flex-1 px-4 py-6">
      <ul class="space-y-1">
        {navLinks.map((link) => (
          <li>
            {link.hasDropdown ? (
              <div>
                <button
                  class="mobile-services-toggle w-full flex items-center justify-between py-3 text-lg font-medium text-text"
                  aria-expanded="false"
                >
                  {link.name}
                  <svg class="w-5 h-5 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                  </svg>
                </button>
                <ul class="mobile-services-list hidden pl-4 space-y-1 pb-2">
                  {services.map((service) => (
                    <li>
                      <a
                        href={service.href}
                        class:list={[
                          'block py-2 text-base transition-colors',
                          isActive(service.href)
                            ? 'text-primary font-medium'
                            : 'text-muted hover:text-primary',
                        ]}
                      >
                        {service.name}
                      </a>
                    </li>
                  ))}
                </ul>
              </div>
            ) : (
              <a
                href={link.href}
                class:list={[
                  'block py-3 text-lg font-medium transition-colors',
                  isActive(link.href)
                    ? 'text-primary'
                    : 'text-text hover:text-primary',
                ]}
              >
                {link.name}
              </a>
            )}
          </li>
        ))}
      </ul>
    </nav>

    <!-- Mobile menu CTAs -->
    <div class="px-4 pb-8 space-y-3">
      <a href={`${base}/book-online`} class="btn-accent w-full text-center">Book Now</a>
      <a href="tel:9515472056" class="btn-outline w-full text-center">
        <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
        </svg>
        Call 951-547-2056
      </a>
    </div>
  </div>
</header>

<script>
  const menuBtn = document.getElementById('mobile-menu-btn');
  const menuClose = document.getElementById('mobile-menu-close');
  const mobileMenu = document.getElementById('mobile-menu');
  const iconOpen = document.getElementById('menu-icon-open');
  const iconClose = document.getElementById('menu-icon-close');

  function openMenu() {
    mobileMenu?.classList.remove('hidden');
    mobileMenu?.classList.add('flex');
    document.body.style.overflow = 'hidden';
    menuBtn?.setAttribute('aria-expanded', 'true');
    iconOpen?.classList.add('hidden');
    iconClose?.classList.remove('hidden');
  }

  function closeMenu() {
    mobileMenu?.classList.add('hidden');
    mobileMenu?.classList.remove('flex');
    document.body.style.overflow = '';
    menuBtn?.setAttribute('aria-expanded', 'false');
    iconOpen?.classList.remove('hidden');
    iconClose?.classList.add('hidden');
  }

  menuBtn?.addEventListener('click', openMenu);
  menuClose?.addEventListener('click', closeMenu);

  // Services sub-menu toggle
  document.querySelectorAll('.mobile-services-toggle').forEach((btn) => {
    btn.addEventListener('click', () => {
      const list = btn.nextElementSibling as HTMLElement | null;
      const arrow = btn.querySelector('svg');
      const expanded = btn.getAttribute('aria-expanded') === 'true';

      if (list) {
        list.classList.toggle('hidden');
      }
      if (arrow) {
        arrow.classList.toggle('rotate-180');
      }
      btn.setAttribute('aria-expanded', String(!expanded));
    });
  });
</script>
