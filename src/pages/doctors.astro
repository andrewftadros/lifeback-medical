---
import BaseLayout from '@layouts/BaseLayout.astro';
import HeroSection from '@components/HeroSection.astro';
import DoctorCard from '@components/DoctorCard.astro';
import CTABanner from '@components/CTABanner.astro';

const doctors = [
  {
    name: 'Dr. Michael Sedrak, M.D.',
    specialty: 'Medical & Bariatric Director',
    bio: `Dr. Michael Sedrak M.D. joined our multiple specialties practices as both the Medical and Bariatric Director. He's passionate about staying on the cutting edge of advanced minimally invasive and robotic surgical procedures. His desire for knowledge and guidance sets the bar for patient care standards extremely high. Dr. Sedrak applies minimally invasive techniques to all areas of general surgery — procedures involve smaller incisions, shorter operating hours, less recovery time and most importantly, less pain for patients. He also specializes in bariatric and esophageal surgery, gastroesophageal reflux disease (GERD), cancer and endoscopy. His research has centered around regenerative bioengineering and repair, and microvascular and vascular tissue engineering. Dr. Sedrak has been active in research at the UC San Diego Surgical Research Lab and the Center for the Future of Surgery. Almost equally important, he has undergone multiple of the curative surgeries he performs — making him not just a clinical expert but an experienced patient.

Board Certification: Diplomate of the American Board of Surgery. Academic Appointments: Assistant Professor at USC, Clinical Instructor at UC San Diego. Education: M.D. from University of South Alabama College of Medicine, B.S. in Biochemistry from UC Riverside. Postgraduate training includes Minimally Invasive Surgery at UC San Diego, Residency at NYU and Charles R. Drew University, and Internship at Cedars-Sinai Medical Center.`,
    image: '/images/doctors/dr-sedrak.jpg',
  },
  {
    name: 'Dr. Paul Bressman, M.D., FACS, RVT',
    specialty: 'Vascular & Venous Specialist',
    bio: `Dr. Paul Bressman M.D. is a Diplomate of the American Board of Surgery, a Fellow of the American College of Surgery (FACS) and a Registered Vascular Technician (RVT). He completed an additional clinical fellowship in peripheral vascular surgery at Cedars Sinai Medical Center in Los Angeles, California. Dr. Bressman is a Diplomate of the American Board of Phlebology and has dedicated his practice to taking care of patients with the full spectrum of venous disorders. Treatment is based upon a complete consultation, a full venous duplex ultrasound examination, and tailored to meet each patient's unique needs. The practice employs both Laser and Vnus Coviden Radiofrequency endovenous ablation therapy, ultrasound guided foam sclerotherapy and Microphlebectomy, utilizing PPO or Medicare Insurance benefits whenever possible.`,
    image: '/images/doctors/clinic-1.jpg',
  },
  {
    name: 'Dr. Kashif Zuberi, M.D.',
    specialty: 'Minimally Invasive Surgery Specialist',
    bio: `Dr. Zuberi M.D. is a board certified, minimally invasive specialist with special interests in surgical and endoscopic management for GERD, bariatric surgery and weight loss management, robotic surgery, advanced endoscopy and general surgery. His clinical experience includes Sanford Bemidji Main Clinic, CHI Lakewood Health Center and Beaumont Hospital. Dr. Zuberi graduated from and served his residency at the Royal College of Surgeons in Dublin, Ireland (RCSI). He also served his residency at Johns Hopkins School of Medicine in Baltimore, MD, and the Marshfield Clinic and St. Joseph's Hospital in Marshfield, WI. Certified by the American Board of Surgery, Dr. Zuberi is excited to serve the Inland Empire and surrounding communities.`,
    image: '/images/doctors/clinic-2.jpg',
  },
  {
    name: 'Dr. Eduardo Munoz, M.D.',
    specialty: 'Bariatric Surgery Specialist',
    bio: `Dr. Eduardo Munoz is a highly skilled, internationally trained physician who believes patient care should be a physician's priority. After obtaining his medical degree from Montemorelos University, he gained remarkable experience and competence in bariatric surgery at some of Mexico's busiest hospitals in the Monterey area. He continued his training in Canada, expanding his mastery in surgical abilities across the provinces of Alberta and Ontario. He has had the privilege to train with world-renowned surgeons in Southern California, where he has worked as clinical coordinator for several bariatric surgical practices. He is committed to academic growth and medical excellence and has completed various courses from Stanford University and Johns Hopkins University, where he is currently involved in a bariatric surgery research project.`,
    image: '/images/doctors/clinic-3.jpg',
  },
];
---

<BaseLayout title="Meet Our Doctors" description="Meet the experienced, compassionate physicians at Life Back Medical. Board-certified specialists dedicated to your care.">

  <!-- Hero -->
  <HeroSection
    title="Meet Our Doctors"
    subtitle="Experienced, compassionate specialists dedicated to your care"
    size="short"
  />

  <!-- Doctors -->
  <section class="section-padding bg-light-bg">
    <div class="container-default fade-in">
      <div class="space-y-8">
        {doctors.map((doctor) => (
          <DoctorCard
            name={doctor.name}
            specialty={doctor.specialty}
            bio={doctor.bio}
            image={doctor.image}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <CTABanner title="Ready to schedule your visit?" />

</BaseLayout>
