---
import BaseLayout from '@layouts/BaseLayout.astro';
import HeroSection from '@components/HeroSection.astro';
import CTABanner from '@components/CTABanner.astro';
---

<BaseLayout title="Locations" description="Find Life Back Medical's offices in Beverly Hills and Corona, CA. Two convenient locations to serve you. Call 951-547-2056.">

  <!-- Hero -->
  <HeroSection
    title="Our Locations"
    subtitle="Conveniently located to serve you"
    size="short"
  />

  <!-- Locations -->
  <section class="section-padding bg-white">
    <div class="container-default fade-in">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">

        <!-- Beverly Hills Location -->
        <div class="card p-8">
          <h2 class="text-2xl md:text-3xl font-bold text-dark mb-6">Beverly Hills</h2>
          <div class="space-y-5">
            <!-- Address -->
            <div class="flex items-start gap-4">
              <svg class="w-6 h-6 text-primary flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
              <div>
                <p class="font-semibold text-dark">Address</p>
                <p class="text-muted">8907 Wilshire Blvd, Suite #100</p>
                <p class="text-muted">465 N. Roxbury Dr.</p>
                <p class="text-muted">Beverly Hills, CA 90210</p>
              </div>
            </div>
            <!-- Phone -->
            <div class="flex items-start gap-4">
              <svg class="w-6 h-6 text-primary flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
              <div>
                <p class="font-semibold text-dark">Phone</p>
                <a href="tel:9515472056" class="text-primary hover:text-primary-light transition-colors">951-547-2056</a>
              </div>
            </div>
            <!-- Email -->
            <div class="flex items-start gap-4">
              <svg class="w-6 h-6 text-primary flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
              <div>
                <p class="font-semibold text-dark">Email</p>
                <a href="mailto:info@lifebackmedical.com" class="text-primary hover:text-primary-light transition-colors">info@LifeBackMedical.com</a>
              </div>
            </div>
            <!-- Hours -->
            <div class="flex items-start gap-4">
              <svg class="w-6 h-6 text-primary flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              <div>
                <p class="font-semibold text-dark">Hours</p>
                <p class="text-muted">Monday - Sunday: 8:00 AM - 7:00 PM</p>
              </div>
            </div>
            <!-- Map -->
            <div class="mt-4 rounded-card overflow-hidden h-56">
              <iframe
                src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3305.0!2d-118.3886!3d34.0625!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2s8907+Wilshire+Blvd+Beverly+Hills+CA+90210!5e0!3m2!1sen!2sus!4v1"
                width="100%"
                height="100%"
                style="border:0;"
                allowfullscreen=""
                loading="lazy"
                referrerpolicy="no-referrer-when-downgrade"
                title="Beverly Hills office map"
              ></iframe>
            </div>
          </div>
        </div>

        <!-- Corona Location -->
        <div class="card p-8">
          <h2 class="text-2xl md:text-3xl font-bold text-dark mb-6">Corona</h2>
          <div class="space-y-5">
            <!-- Address -->
            <div class="flex items-start gap-4">
              <svg class="w-6 h-6 text-primary flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
              <div>
                <p class="font-semibold text-dark">Address</p>
                <p class="text-muted">1902 Fullerton Ave, Suite #101</p>
                <p class="text-muted">Corona, CA 92881</p>
              </div>
            </div>
            <!-- Phone -->
            <div class="flex items-start gap-4">
              <svg class="w-6 h-6 text-primary flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
              <div>
                <p class="font-semibold text-dark">Phone</p>
                <a href="tel:9515472056" class="text-primary hover:text-primary-light transition-colors">951-547-2056</a>
              </div>
            </div>
            <!-- Email -->
            <div class="flex items-start gap-4">
              <svg class="w-6 h-6 text-primary flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
              <div>
                <p class="font-semibold text-dark">Email</p>
                <a href="mailto:info@lifebackmedical.com" class="text-primary hover:text-primary-light transition-colors">info@LifeBackMedical.com</a>
              </div>
            </div>
            <!-- Hours -->
            <div class="flex items-start gap-4">
              <svg class="w-6 h-6 text-primary flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              <div>
                <p class="font-semibold text-dark">Hours</p>
                <p class="text-muted">Monday - Sunday: 8:00 AM - 7:00 PM</p>
              </div>
            </div>
            <!-- Map -->
            <div class="mt-4 rounded-card overflow-hidden h-56">
              <iframe
                src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3312.0!2d-117.5656!3d33.8753!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2s1902+Fullerton+Ave+Corona+CA+92881!5e0!3m2!1sen!2sus!4v1"
                width="100%"
                height="100%"
                style="border:0;"
                allowfullscreen=""
                loading="lazy"
                referrerpolicy="no-referrer-when-downgrade"
                title="Corona office map"
              ></iframe>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- CTA -->
  <CTABanner
    title="Visit us today"
    buttonText="Get Directions"
    buttonHref="https://www.google.com/maps/search/Life+Back+Medical"
  />

</BaseLayout>
